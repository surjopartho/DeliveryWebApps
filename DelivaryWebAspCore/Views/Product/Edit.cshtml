@model DelivaryWebAspCore.Models.Product

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow border-0 rounded-3">
                <div class="card-body p-4">

                    <h3 class="text-center mb-4 fw-bold">Edit Product</h3>

                    <form asp-action="Edit" method="post">

                        <input type="hidden" asp-for="ProductId" />
                        <input type="hidden" asp-for="ProductPrice" />
                        <input type="hidden" asp-for="Charge" />
                        <input type="hidden" asp-for="SellerId" />

                        <div class="form-group mb-3">
                            <input asp-for="CustomerName" class="form-control" placeholder="Customer Name" />
                        </div>

                        <div class="form-group mb-3">
                            <input asp-for="ProductName" class="form-control" placeholder="Product Name" />
                        </div>

                        <div class="form-group mb-3">
                            <input asp-for="Weight" type="number" step="0.01" class="form-control" placeholder="Weight" />
                        </div>
                        <div class="form-group mb-3">
                            <input asp-for="CustomerLocation" class="form-control" placeholder="Location"/>
                        </div>

                        <div class="form-group mb-4">
                            <select asp-for="IsType" class="form-control"
                                    asp-items="Html.GetEnumSelectList<DelivaryWebAspCore.Models.TypeOfProduct>()">
                                <option value="">Select Type</option>
                            </select>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-warning fw-bold">Update Product</button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>