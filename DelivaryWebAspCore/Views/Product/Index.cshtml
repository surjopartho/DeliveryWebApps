@model IEnumerable<DelivaryWebAspCore.Models.Product>
@using DelivaryWebAspCore.Models

@{
    ViewData["Title"] = "Product Delivery list";
}

<div class="container-fluid mt-4">
    <div class="row">

        <div class="col-md-5 border-end pe-4 mb-4">
            <h2>Product</h2>
            <br />

            <div asp-validation-summary="All" class="text-danger"></div>

            <form asp-action="Index" method="post">

                <div>
                    <input name="CustomerName" placeholder="Enter Your Customer Name" class="form-control" required />
                </div>
                <br />

                <div>
                    <input name="CustomerLocation" placeholder="Customer Location" class="form-control" required />
                </div>
                <br />

                <div>
                    <input name="ProductName" placeholder="Enter Product Name" class="form-control" required />
                </div>
                <br />

                <div>
                    <input name="Weight" placeholder="Enter Weight (Kg)" type="number" step="0.01" class="form-control" required />
                </div>
                <br />

                <select name="IsType" class="form-control" asp-items="Html.GetEnumSelectList<TypeOfProduct>()" required>
                    <option value="">Select Product Type</option>
                </select>
                <br />

                <button type="submit" class="btn btn-primary w-100">
                    Save Product
                </button>
            </form>
        </div>

        <div class="col-md-7 ps-4">
            <h2>Product List</h2>
            <br />

            @if (Model == null || !Model.Any())
            {
                <div class="alert alert-info">
                    No products available yet.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Product Name</th>
                                <th>Location</th>
                                <th>Weight</th>
                                <th>Customer Name</th>
                                <th>Type</th>
                                <th>Total Bill</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int serial = 1;
                            }

                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@serial</td>
                                    <td>@item.ProductName</td>
                                    <td>@item.CustomerLocation</td>
                                    <td>@item.Weight Kg</td>
                                    <td>@item.CustomerName</td>
                                    <td>
                                        <span class="badge bg-info text-dark">@item.IsType</span>
                                    </td>
                                    <td>@item.Charge</td>

                                    <td>
                                        <span class="badge @(item.Status == DeliveryStatus.Delivered ? "bg-success" : "bg-primary")">
                                            @item.Status
                                        </span>
                                    </td>

                                    <td>
                                        <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-warning">
                                            Edit
                                        </a>

                                        <a asp-action="Delete" asp-route-id="@item.ProductId"
                                           class="btn btn-sm btn-danger"
                                           onclick="return confirm('Are you sure you want to delete this product?')">
                                            Delete
                                        </a>
                                    </td>
                                </tr>
                                serial++;
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

    </div>
</div>